{
  "name": "@toodoori/mcp",
  "version": "0.1.0",
  "type": "module",
  "description": "toodoori MCP server — LLM이 toodoori 할 일 관리를 수행하도록 /api/v1을 감싸는 얇은 stdio MCP 서버 (PAT bearer)",
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "toodoori",
    "claude",
    "todo",
    "task-management"
  ],
  "homepage": "https://github.com/peoplenex/toodoori-server/tree/main/mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peoplenex/toodoori-server.git",
    "directory": "mcp"
  },
  "bin": {
    "toodoori-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "yarn build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
